# ======================================================
# Luna Legal AI — Environment Variables
# ======================================================
# Copy this file:  cp .env.example .env
# Then fill in the secret values from your Supabase dashboard.
#
# Real project URLs (not secrets — safe to include):
#   Supabase:  https://dwgghvxogtwyaxmbgjod.supabase.co
#   Backend:   https://luna-backend-production-35ba.up.railway.app
#   Frontend:  https://luna-frontend-production-1124.up.railway.app
# ======================================================

# ------ Supabase ------
# Dashboard → Settings → API
SUPABASE_URL=https://dwgghvxogtwyaxmbgjod.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional: direct Postgres URL (for running migrations locally)
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.dwgghvxogtwyaxmbgjod.supabase.co:5432/postgres

# ------ Redis ------
# Local dev: use docker-compose (redis://localhost:6379)
# Railway:   use the internal URL (redis://default:password@redis.railway.internal:6379)
#            or public URL (redis://default:password@hopper.proxy.rlwy.net:11864)
REDIS_URL=redis://localhost:6379

# ------ Backend ------
ENVIRONMENT=development
DEBUG=true
PORT=8000
LOG_LEVEL=INFO

# Comma-separated allowed origins for CORS
# Local dev:  http://localhost:3000
# Production: https://luna-frontend-production-1124.up.railway.app
CORS_ORIGINS=http://localhost:3000

# ------ Frontend (Next.js public env vars) ------
NEXT_PUBLIC_SUPABASE_URL=https://dwgghvxogtwyaxmbgjod.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------ AI / LLM (not needed for Steps 1-2) ------
# OPENROUTER_API_KEY=your-openrouter-key
# MISTRAL_API_KEY=your-mistral-key
# OPENAI_API_KEY=your-openai-key

# ------ Alibaba DashScope (default embedding provider) ------
# Used for regulation search embeddings (text-embedding-v3, 1024-dim).
# OpenAI-compatible API — get key from: https://dashscope-intl.aliyuncs.com
# ALIBABA_API_KEY=sk-your-dashscope-key
# ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# ALIBABA_EMBEDDING_MODEL=text-embedding-v3
# ALIBABA_EMBEDDING_DIMENSIONS=1024
